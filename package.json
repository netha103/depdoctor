{
  "name": "dep-health-cli",
  "version": "0.1.7",
  "description": "Production-grade developer dependency and code health CLI",
  "main": "dist/index.js",
  "bin": {
    "depdoctor": "bin/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli/index.ts",
    "start": "node dist/cli/index.js",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "cli",
    "dependencies",
    "unused",
    "security",
    "analysis",
    "typescript",
    "dead-code",
    "audit"
  ],
  "author": "Nethaji LP <netha103@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/netha103/depdoctor.git"
  },
  "homepage": "https://github.com/netha103/depdoctor#readme",
  "bugs": {
    "url": "https://github.com/netha103/depdoctor/issues"
  },
  "dependencies": {
    "@babel/parser": "^7.23.0",
    "@babel/traverse": "^7.23.0",
    "@babel/types": "^7.23.0",
    "chalk": "^5.3.0",
    "commander": "^11.1.0",
    "glob": "^10.3.10",
    "ora": "^7.0.1",
    "pdfkit": "^0.18.0",
    "recast": "^0.23.4",
    "semver": "^7.5.4",
    "typescript": "^5.3.2"
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@types/babel__traverse": "^7.20.4",
    "@types/node": "^20.10.0",
    "@types/pdfkit": "^0.17.6",
    "@types/semver": "^7.5.6",
    "tsx": "^4.6.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "bin",
    "dist",
    "README.md"
  ]
}
